{
  "name": "agent-service",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" }
  },

  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "containerEnv": {
    "LOKI_PUSH_URL": "https://loki.woodhost.cloud/loki/api/v1/push",
    "LOGGING_ENVIRONMENT": "dev",
    "LOGGING_SERVICE": "agent-service-devcontainer"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/workspace/backend/.venv/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "openai.chatgpt"
      ]
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/start-dev.sh",

  "forwardPorts": [8000],

  "runArgs": [
    "--init",
    "--label=logging.environment=dev",
    "--label=logging.service=agent-service-devcontainer",
    "--log-driver=json-file",
    "--log-opt=max-size=10m",
    "--log-opt=max-file=5",
    "--log-opt=labels=logging.environment,logging.service"
  ],

  "remoteUser": "vscode"
}
